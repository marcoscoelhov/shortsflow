[Unit]
Description=YTS Render daily automation cycle
After=network-online.target tailscaled.service yts-render-hub.service yts-render-vision.service
Wants=network-online.target tailscaled.service yts-render-vision.service

[Service]
Type=oneshot
WorkingDirectory=__REPO_ROOT__
Environment=YTS_REPO_ROOT=__REPO_ROOT__
ExecStart=__REPO_ROOT__/.venv/bin/python -m app.cli automation-run
