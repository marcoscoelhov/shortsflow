# Copie este arquivo para .env e preencha apenas o necessario para seu ambiente.
# Nunca versionar o .env real: ele pode conter tokens, chaves e credenciais OAuth.
# Booleanos usam true/false; duracoes e timeouts usam segundos, salvo indicacao.
# Variaveis comentadas mostram overrides opcionais e mantem o padrao da aplicacao.

# -----------------------------------------------------------------------------
# Hub e acesso
# -----------------------------------------------------------------------------
YTS_APP_NAME=ShortsFlow
# URL publica usada em links e callbacks. Host e porta controlam o bind local.
YTS_APP_URL=http://127.0.0.1:8080
YTS_APP_HOST=127.0.0.1
YTS_APP_PORT=8080
# Se preenchido, protege o Hub. Use um valor longo, aleatorio e exclusivo.
YTS_HUB_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Persistencia local
# -----------------------------------------------------------------------------
# Mantenha o diretorio e a URL SQLite apontando para o mesmo ambiente.
YTS_DATA_DIR=data
YTS_DATABASE_URL=sqlite:///data/shortsflow.db

# -----------------------------------------------------------------------------
# Gates de qualidade, render e verificacao visual
# -----------------------------------------------------------------------------
# Gate final premium antes de aprovar/agendar/publicar.
YTS_PREMIUM_PUBLISH_MIN_SCORE=9.2
# Juiz LLM para gates editoriais (viral, metadata, visual, growth) em zona cinza.
YTS_LLM_GATE_JUDGE_ENABLED=true
YTS_LLM_GATE_JUDGE_PROVIDER=openai
YTS_LLM_GATE_JUDGE_MODEL=gpt-5.4
YTS_LLM_GATE_JUDGE_TIMEOUT_SEC=45
YTS_LLM_GATE_GRAY_ZONE_LOW=0.72
YTS_LLM_GATE_GRAY_ZONE_HIGH=0.82
# Render principal operacional.
YTS_RENDER_PRIMARY_BACKEND=remotion
# Verificador visual real para liberar revisao visual automatica.
# Instale o servico local com scripts/install_local_vision_service.sh.
YTS_VISION_VERIFIER_PROVIDER=local_openai
YTS_LOCAL_VISION_BASE_URL=http://127.0.0.1:8081/v1
YTS_LOCAL_VISION_MODEL=minicpm-v-4.6-q4
YTS_VISION_VERIFIER_TIMEOUT_SEC=240

# -----------------------------------------------------------------------------
# Roteamento e credenciais de LLM
# -----------------------------------------------------------------------------
# O provider primario deve ter sua chave preenchida. Os demais sao opcionais e
# podem ser usados por fallback, reparo ou selecao feita no Hub.
YTS_LLM_PRIMARY_PROVIDER=deepseek
YTS_OPENAI_API_KEY=
YTS_DEEPSEEK_API_KEY=
YTS_QWEN_API_KEY=
YTS_XAI_API_KEY=
YTS_XAI_BASE_URL=https://api.x.ai/v1
YTS_XAI_MODEL=grok-4.20-non-reasoning
YTS_XAI_TIMEOUT_SEC=180

# -----------------------------------------------------------------------------
# MiniMax, texto, imagens e musica
# -----------------------------------------------------------------------------
# YTS_MINIMAX_API_KEY e um fallback compartilhado. Prefira chaves separadas.
YTS_MINIMAX_API_KEY=
YTS_MINIMAX_TEXT_API_KEY=
YTS_MINIMAX_IMAGE_API_KEY=
YTS_MINIMAX_MUSIC_API_KEY=
YTS_MINIMAX_TEXT_MODEL=MiniMax-M2.7
YTS_MINIMAX_TEXT_THINKING=auto

# -----------------------------------------------------------------------------
# Narracao (TTS)
# -----------------------------------------------------------------------------
# Gemini usa YTS_GEMINI_API_KEY como fallback quando a chave dedicada nao existe.
YTS_TTS_PRIMARY_PROVIDER=gemini_tts
YTS_GEMINI_API_KEY=
# YTS_GEMINI_TTS_API_KEY=
# YTS_GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
# YTS_GEMINI_TTS_VOICE_NAME=Kore
# YTS_GEMINI_TTS_VOICE_ROTATION_ENABLED=true
# YTS_GEMINI_TTS_STYLE_PROMPT=Narre em portugues brasileiro natural, com ritmo humano de documentario curto, sem soar sintetico ou robotico.
YTS_ELEVENLABS_API_KEY=
# YTS_ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
# YTS_ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# -----------------------------------------------------------------------------
# Publicacao no YouTube
# -----------------------------------------------------------------------------
# O callback vazio e derivado de YTS_APP_URL. Credenciais nao habilitam a
# publicacao sozinhas; modo e automacao sao controlados pelo Hub.
YTS_YOUTUBE_CHANNEL_ID=
YTS_YOUTUBE_CLIENT_ID=
YTS_YOUTUBE_CLIENT_SECRET=
YTS_YOUTUBE_OAUTH_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Publicacao no TikTok
# -----------------------------------------------------------------------------
# Token manual com escopo video.publish. O Hub nao renova esse token.
YTS_TIKTOK_ACCESS_TOKEN=
# YTS_TIKTOK_AUTO_PUBLISH_ENABLED=false
# YTS_TIKTOK_PRIVACY_LEVEL=PUBLIC_TO_EVERYONE
# YTS_TIKTOK_RETROPOST_DAILY_LIMIT=1

# -----------------------------------------------------------------------------
# Bancos de assets externos, opcionais
# -----------------------------------------------------------------------------
YTS_PEXELS_API_KEY=
YTS_PIXABAY_API_KEY=

# -----------------------------------------------------------------------------
# Exposicao via Tailscale
# -----------------------------------------------------------------------------
YTS_TAILSCALE_HOSTNAME=shorts-hub
YTS_TAILNET_DOMAIN=example.ts.net

# -----------------------------------------------------------------------------
# Overrides avancados de infraestrutura ou SDK
# -----------------------------------------------------------------------------
# Normalmente nao e preciso descomentar. Prefira o Hub para escolher LLM,
# musica, automacao e modo de publicacao.
# YTS_OPENAI_BASE_URL=https://api.openai.com/v1
# YTS_OPENAI_MODEL=gpt-5.4-nano
# YTS_GEMINI_TEXT_MODEL=gemini-3.5-flash
# YTS_GEMINI_TEXT_TIMEOUT_SEC=180
# YTS_DEEPSEEK_BASE_URL=https://api.deepseek.com
# YTS_DEEPSEEK_MODEL=deepseek-v4-flash
# YTS_QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# YTS_QWEN_MODEL=qwen3.6-max-preview
# YTS_MINIMAX_TEXT_BASE_URL=https://api.minimax.io/v1
# YTS_MINIMAX_IMAGE_BASE_URL=https://api.minimax.io/v1/image_generation
# YTS_MINIMAX_IMAGE_ASPECT_RATIO=9:16
# YTS_MINIMAX_MUSIC_BASE_URL=https://api.minimax.io/v1
