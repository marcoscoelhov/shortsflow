# Copie este arquivo para .env e preencha apenas o necessario para seu ambiente.
# Nunca versionar o .env real: ele pode conter tokens, chaves e credenciais OAuth.
# Booleanos usam true/false; duracoes e timeouts usam segundos, salvo indicacao.
# Variaveis comentadas mostram overrides opcionais e mantem o padrao da aplicacao.

# -----------------------------------------------------------------------------
# Hub e acesso
# -----------------------------------------------------------------------------
SHORTSFLOW_APP_NAME=ShortsFlow
# URL publica usada em links e callbacks. Host e porta controlam o bind local.
SHORTSFLOW_APP_URL=http://127.0.0.1:8080
SHORTSFLOW_APP_HOST=127.0.0.1
SHORTSFLOW_APP_PORT=8080
# Se preenchido, protege o Hub. Use um valor longo, aleatorio e exclusivo.
SHORTSFLOW_HUB_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Persistencia local
# -----------------------------------------------------------------------------
# Mantenha o diretorio e a URL SQLite apontando para o mesmo ambiente.
SHORTSFLOW_DATA_DIR=data
SHORTSFLOW_DATABASE_URL=sqlite:///data/shortsflow.db

# -----------------------------------------------------------------------------
# Gates de qualidade, render e verificacao visual
# -----------------------------------------------------------------------------
# Gate final premium antes de aprovar/agendar/publicar.
SHORTSFLOW_PREMIUM_PUBLISH_MIN_SCORE=9.2
# Juiz LLM para gates editoriais (viral, metadata, visual, growth) em zona cinza.
SHORTSFLOW_LLM_GATE_JUDGE_ENABLED=true
SHORTSFLOW_LLM_GATE_JUDGE_PROVIDER=deepseek
SHORTSFLOW_LLM_GATE_JUDGE_MODEL=deepseek-v4-flash
SHORTSFLOW_LLM_GATE_JUDGE_TIMEOUT_SEC=45
SHORTSFLOW_LLM_JSON_MAX_TOKENS=4096
SHORTSFLOW_LLM_GATE_GRAY_ZONE_LOW=0.72
SHORTSFLOW_LLM_GATE_GRAY_ZONE_HIGH=0.82
# Render principal operacional.
SHORTSFLOW_PRIMARY_BACKEND=remotion
# Verificador visual real para liberar revisao visual automatica.
# Instale o servico local com scripts/install_local_vision_service.sh.
SHORTSFLOW_VISION_VERIFIER_PROVIDER=local_openai
SHORTSFLOW_LOCAL_VISION_BASE_URL=http://127.0.0.1:8081/v1
SHORTSFLOW_LOCAL_VISION_MODEL=minicpm-v-4.6-q4
SHORTSFLOW_VISION_VERIFIER_TIMEOUT_SEC=240

# -----------------------------------------------------------------------------
# Roteamento e credenciais de LLM
# -----------------------------------------------------------------------------
# O provider primario deve ter sua chave preenchida. Os demais sao opcionais e
# podem ser usados por fallback, reparo ou selecao feita no Hub.
SHORTSFLOW_LLM_PRIMARY_PROVIDER=deepseek
SHORTSFLOW_OPENAI_API_KEY=
SHORTSFLOW_DEEPSEEK_API_KEY=
SHORTSFLOW_QWEN_API_KEY=
SHORTSFLOW_XAI_API_KEY=
SHORTSFLOW_XAI_BASE_URL=https://api.x.ai/v1
SHORTSFLOW_XAI_MODEL=grok-4.20-non-reasoning
SHORTSFLOW_XAI_TIMEOUT_SEC=180

# -----------------------------------------------------------------------------
# MiniMax, texto, imagens e musica
# -----------------------------------------------------------------------------
# SHORTSFLOW_MINIMAX_API_KEY e um fallback compartilhado. Prefira chaves separadas.
SHORTSFLOW_MINIMAX_API_KEY=
SHORTSFLOW_MINIMAX_TEXT_API_KEY=
SHORTSFLOW_MINIMAX_IMAGE_API_KEY=
SHORTSFLOW_MINIMAX_MUSIC_API_KEY=
SHORTSFLOW_MINIMAX_TEXT_MODEL=MiniMax-M2.7
SHORTSFLOW_MINIMAX_TEXT_THINKING=auto

# -----------------------------------------------------------------------------
# Narracao (TTS)
# -----------------------------------------------------------------------------
# Gemini usa SHORTSFLOW_GEMINI_API_KEY como fallback quando a chave dedicada nao existe.
SHORTSFLOW_TTS_PRIMARY_PROVIDER=gemini_tts
SHORTSFLOW_GEMINI_API_KEY=
# SHORTSFLOW_GEMINI_TTS_API_KEY=
# SHORTSFLOW_GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
# SHORTSFLOW_GEMINI_TTS_VOICE_NAME=Kore
# SHORTSFLOW_GEMINI_TTS_VOICE_ROTATION_ENABLED=true
# SHORTSFLOW_GEMINI_TTS_STYLE_PROMPT=Narre em portugues brasileiro natural, com ritmo humano de documentario curto, sem soar sintetico ou robotico.
SHORTSFLOW_ELEVENLABS_API_KEY=
# SHORTSFLOW_ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
# SHORTSFLOW_ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# -----------------------------------------------------------------------------
# Publicacao no YouTube
# -----------------------------------------------------------------------------
# O callback vazio e derivado de SHORTSFLOW_APP_URL. Credenciais nao habilitam a
# publicacao sozinhas; modo e automacao sao controlados pelo Hub.
SHORTSFLOW_YOUTUBE_CHANNEL_ID=
SHORTSFLOW_YOUTUBE_CLIENT_ID=
SHORTSFLOW_YOUTUBE_CLIENT_SECRET=
SHORTSFLOW_YOUTUBE_OAUTH_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Publicacao no TikTok
# -----------------------------------------------------------------------------
# Token manual com escopo video.publish. O Hub nao renova esse token.
SHORTSFLOW_TIKTOK_ACCESS_TOKEN=
# SHORTSFLOW_TIKTOK_AUTO_PUBLISH_ENABLED=false
# SHORTSFLOW_TIKTOK_PRIVACY_LEVEL=PUBLIC_TO_EVERYONE
# SHORTSFLOW_TIKTOK_RETROPOST_DAILY_LIMIT=1

# -----------------------------------------------------------------------------
# Bancos de assets externos, opcionais
# -----------------------------------------------------------------------------
SHORTSFLOW_PEXELS_API_KEY=
SHORTSFLOW_PIXABAY_API_KEY=

# -----------------------------------------------------------------------------
# Exposicao via Tailscale
# -----------------------------------------------------------------------------
SHORTSFLOW_TAILSCALE_HOSTNAME=shorts-hub
SHORTSFLOW_TAILNET_DOMAIN=example.ts.net

# -----------------------------------------------------------------------------
# Overrides avancados de infraestrutura ou SDK
# -----------------------------------------------------------------------------
# Normalmente nao e preciso descomentar. Prefira o Hub para escolher LLM,
# musica, automacao e modo de publicacao.
# SHORTSFLOW_OPENAI_BASE_URL=https://api.openai.com/v1
# SHORTSFLOW_OPENAI_MODEL=gpt-5.4-nano
# SHORTSFLOW_GEMINI_TEXT_MODEL=gemini-3.5-flash
# SHORTSFLOW_GEMINI_TEXT_TIMEOUT_SEC=180
# SHORTSFLOW_DEEPSEEK_BASE_URL=https://api.deepseek.com
# SHORTSFLOW_DEEPSEEK_MODEL=deepseek-v4-flash
# SHORTSFLOW_QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# SHORTSFLOW_QWEN_MODEL=qwen3.6-max-preview
# SHORTSFLOW_MINIMAX_TEXT_BASE_URL=https://api.minimax.io/v1
# SHORTSFLOW_MINIMAX_IMAGE_BASE_URL=https://api.minimax.io/v1/image_generation
# SHORTSFLOW_MINIMAX_IMAGE_ASPECT_RATIO=9:16
# SHORTSFLOW_MINIMAX_MUSIC_BASE_URL=https://api.minimax.io/v1
