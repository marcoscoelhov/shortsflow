YTS_APP_NAME=YTS Render
YTS_APP_HOST=127.0.0.1
YTS_APP_PORT=8080
YTS_DATA_DIR=data
YTS_DATABASE_URL=sqlite:///data/yts_render.db
YTS_TARGET_DURATION_SEC=35
YTS_SCENE_TARGET_COUNT=6
YTS_USE_MOCK_PROVIDERS=false
YTS_LLM_PRIMARY_PROVIDER=minimax
YTS_LLM_FALLBACK_PROVIDER=mock
YTS_LLM_ENABLE_FALLBACK=true
YTS_LLM_SCRIPT_REPAIR_ATTEMPTS=1
YTS_SCENE_PROMPT_GATE_ENABLED=true
YTS_ASSET_SEMANTIC_THRESHOLD=0.80
YTS_ASSET_TOTAL_THRESHOLD=0.75
YTS_RENDER_MIN_BITRATE=250000
YTS_YOUTUBE_PUBLISH_MODE=manual
YTS_YOUTUBE_API_ENABLED=false
YTS_YOUTUBE_CHANNEL_ID=
YTS_MINIMAX_API_KEY=
YTS_MINIMAX_TEXT_API_KEY=
YTS_MINIMAX_IMAGE_API_KEY=
YTS_MINIMAX_TEXT_BASE_URL=https://api.minimax.io/v1
YTS_MINIMAX_IMAGE_BASE_URL=https://api.minimax.io/v1/image_generation
YTS_MINIMAX_TEXT_TIMEOUT_SEC=120
YTS_MINIMAX_SCENE_PLAN_TIMEOUT_SEC=90
YTS_PEXELS_API_KEY=
YTS_PIXABAY_API_KEY=
YTS_TAILSCALE_HOSTNAME=shorts-hub
YTS_TAILNET_DOMAIN=example.ts.net
